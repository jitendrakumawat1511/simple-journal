{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#ffffff",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#111111",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#f3f4f6",
					"name": "Secondary Base",
					"slug": "secondary-base"
				},
				{
					"color": "#4b5563",
					"name": "Secondary Contrast",
					"slug": "secondary-contrast"
				},
				{
					"color": "#3b82f6",
					"name": "Primary",
					"slug": "primary"
				}
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"size": "0.5rem",
					"slug": "10",
					"name": "1"
				},
				{
					"size": "1rem",
					"slug": "20",
					"name": "2"
				},
				{
					"size": "1.5rem",
					"slug": "30",
					"name": "3"
				},
				{
					"size": "2rem",
					"slug": "40",
					"name": "4"
				},
				{
					"size": "3rem",
					"slug": "50",
					"name": "5"
				},
				{
					"size": "4rem",
					"slug": "60",
					"name": "6"
				},
				{
					"size": "6rem",
					"slug": "70",
					"name": "7"
				},
				{
					"size": "8rem",
					"slug": "80",
					"name": "8"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif",
					"name": "System Sans-serif",
					"slug": "system-sans"
				},
				{
					"fontFamily": "Georgia, Times, \"Times New Roman\", serif",
					"name": "System Serif",
					"slug": "system-serif"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"min": "0.875rem",
						"max": "1rem"
					},
					"size": "1rem",
					"name": "Small",
					"slug": "small"
				},
				{
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					},
					"size": "1.125rem",
					"name": "Medium",
					"slug": "medium"
				},
				{
					"fluid": {
						"min": "1.5rem",
						"max": "1.75rem"
					},
					"size": "1.75rem",
					"name": "Large",
					"slug": "large"
				},
				{
					"fluid": {
						"min": "2rem",
						"max": "2.5rem"
					},
					"size": "2.25rem",
					"name": "Extra Large",
					"slug": "x-large"
				},
				{
					"fluid": {
						"min": "2.5rem",
						"max": "3.5rem"
					},
					"size": "3rem",
					"name": "Extra Extra Large",
					"slug": "xx-large"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"bottom": "calc(0.667em + 2px)",
						"left": "calc(1.333em + 2px)",
						"right": "calc(1.333em + 2px)",
						"top": "calc(0.667em + 2px)"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "none"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-sans)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "400",
					"textTransform": "uppercase"
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-sans)",
					"fontWeight": "800"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-sans)",
					"fontWeight": "800",
					"fontSize": "var(--wp--preset--font-size--large)"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "italic"
				},
				"color": {
					"text": "var(--wp--preset--color--secondary-contrast)"
				}
			},
			"core/group": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)"
					}
				}
			}
		}
	}
}